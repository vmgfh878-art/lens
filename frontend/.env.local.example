# Lens Frontend - local development env
# Copy:  cp .env.local.example .env.local

# Backend API base URL
# Local:    http://localhost:8000  또는 http://127.0.0.1:8000
# Deployed: https://lens-backend-7stj.onrender.com (Render URL)
#
# 만약 비워두면 frontend 코드의 fallback 동작:
#   - 로컬 호스트면 → http://127.0.0.1:8000 사용
#   - 그 외 (배포 도메인) → Render URL 사용
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# (호환용 — 기존 README 가 NEXT_PUBLIC_API_BASE 라고 적었던 잔재.
# 코드는 NEXT_PUBLIC_BACKEND_URL 우선, 없으면 이것도 본다.)
# NEXT_PUBLIC_API_BASE=http://localhost:8000

# (Optional) Direct Supabase access. Not required in v1 local-parquet mode.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
