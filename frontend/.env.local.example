# Lens Frontend - local development env
# Copy:  cp .env.local.example .env.local

# Backend API base URL
# Local:    http://127.0.0.1:8000
# Deployed: https://lens-backend-7stj.onrender.com
#
# 배포 빌드에서는 반드시 Render URL을 명시한다.
# NEXT_PUBLIC_BACKEND_URL이 비어 있으면 화면에 환경 설정 안내가 표시된다.
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# (Optional) Direct Supabase access. Not required in v1 local-parquet mode.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
