# Lens 공통 환경변수 예시

# 프론트가 호출할 백엔드 API 주소.
# 배포 환경에서는 반드시 Render URL을 명시한다.
NEXT_PUBLIC_BACKEND_URL=https://lens-backend-7stj.onrender.com

# 로컬 개발 시에만 아래 값을 사용한다.
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# 백엔드 CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 선택 항목. v1 local-parquet 제품 화면에는 필수가 아니다.
SUPABASE_URL=
SUPABASE_KEY=
FRED_API_KEY=
FMP_API_KEY=
